# Copy to .env and fill in real values (never commit .env; it is gitignored).
# Loaded by launch.sh, the FastAPI service (src/serving.py), and the dashboard.
#
# NO PAID API KEYS ARE REQUIRED. Market data comes from yfinance (free) and
# news evidence from public NYT/Economist RSS feeds (free). The only secrets
# below are LOCAL access controls for your own dashboard/API — nothing here is
# billed or sent to a third party.
#
# Tip: run `make secrets` to auto-generate strong random values into .env.

# Bearer token required by the API (Authorization: Bearer <token>).
ML_EQUITY_API_TOKEN=change-me

# Password gate for the Streamlit research dashboard.
ML_EQUITY_DASHBOARD_PASSWORD=change-me

# --- Optional data/news providers -------------------------------------------
# Not needed for the default setup. Only set these if you deliberately swap in
# a keyed provider (doing so may incur third-party charges you control).
# NEWS_API_KEY=
# MARKET_DATA_API_KEY=
