# ── Quantitative Equity Research Platform Configuration ─────────────────
# Copy this file to .env and adjust as needed.
# Environment variables override all defaults from config/settings.py.

# ── Environment ──────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Data ─────────────────────────────────────────────────────────────────
DEFAULT_START_DATE=2015-01-01
DEFAULT_END_DATE=2025-01-01
YFINANCE_TIMEOUT=30
YFINANCE_MAX_RETRIES=3
DATA_CACHE_ENABLED=true
DATA_CACHE_TTL_HOURS=24

# ── Model Backend ────────────────────────────────────────────────────────
MODEL_BACKEND=auto       # cpu, gpu, or auto
N_JOBS=-1
RANDOM_SEED=42

# ── Validation ───────────────────────────────────────────────────────────
VALIDATION_STRATEGY=walk_forward
N_SPLITS=5
TEST_SIZE=252
MIN_TRAIN_SIZE=756
PURGE_WINDOW=5
EMBARGO_WINDOW=5

# ── Portfolio ────────────────────────────────────────────────────────────
PORTFOLIO_OBJECTIVE=mean_variance
TRANSACTION_COST_BPS=10.0
SLIPPAGE_BPS=5.0
MAX_POSITION_WEIGHT=0.05
MAX_SECTOR_EXPOSURE=0.30
TARGET_LEVERAGE=1.0

# ── Risk ─────────────────────────────────────────────────────────────────
RISK_FREE_RATE=0.05
CONFIDENCE_LEVEL=0.95
COVARIANCE_METHOD=ledoit_wolf

# ── API Security ─────────────────────────────────────────────────────────
API_TOKEN=change-me-in-production
DASHBOARD_PASSWORD=change-me-in-production
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
