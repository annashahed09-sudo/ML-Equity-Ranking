# Copy to .env and fill in real values (never commit .env).
# Loaded by the FastAPI service (src/serving.py) and Streamlit dashboard.

# Bearer token required by the API (Authorization: Bearer <token>).
# In production a missing/default token should be treated as a hard failure.
ML_EQUITY_API_TOKEN=change-me

# Password gate for the Streamlit research dashboard.
ML_EQUITY_DASHBOARD_PASSWORD=change-me

# --- Optional data/news providers -------------------------------------------
# News evidence uses public NYT/Economist RSS feeds and needs no key by default.
# If you swap in a keyed news/market-data provider, add its credentials here.
# NEWS_API_KEY=
# MARKET_DATA_API_KEY=
